<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Main Application Theme -->
    <style name="Theme.DukaanKonnect" parent="@android:style/Theme.Material.NoActionBar">
        <!-- Customize your theme here. -->
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background color -->
        <item name="windowSplashScreenBackground">@color/splash_background</item>

        <!-- Set the splash screen icon -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo_circular</item>

        <!-- Optional: Set icon background color -->
        <item name="windowSplashScreenIconBackgroundColor">@color/splash_icon_background</item>

        <!-- Optional: Set the duration for animated icon -->
        <item name="windowSplashScreenAnimationDuration">1000</item>

        <!-- Set the theme for your app after splash -->
        <item name="postSplashScreenTheme">@style/Theme.DukaanKonnect</item>
    </style>
</resources>
